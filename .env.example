# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=influencers_db

# Runtime toggles
ENABLE_INSTAGRAM=true
ENABLE_YOUTUBE=true
HEADLESS_MODE=true
PROXY_URL=

# Instagram
INSTAGRAM_SESSION_FILE=session_state.json
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_HASHTAGS=indianfitness,fitnessindia
INSTAGRAM_POSTS=12
INSTAGRAM_USERS_PER_HASHTAG=25

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_KEYWORDS=python tutorial,tech reviews
YOUTUBE_SEARCH_RESULTS=3
YOUTUBE_VIDEOS=10
